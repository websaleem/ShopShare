# TestZeus Hercules Configuration
# Copy this file to .env and fill in your Gemini API key from https://aistudio.google.com/app/apikey

LLM_MODEL_NAME=gemini/gemini-1.5-pro
LLM_MODEL_API_KEY=your_gemini_api_key_here

# Browser Settings
BROWSER_TYPE=chromium
HEADLESS=true
RECORD_VIDEO=true
TAKE_SCREENSHOTS=true
