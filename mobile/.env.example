# ShopShare Mobile Environment Variables
# Copy this file to .env and fill in the actual values

# API Gateway Endpoint URL (no trailing slash)
EXPO_PUBLIC_API_URL=https://your-api-id.execute-api.your-region.amazonaws.com

# Cognito User Pool ID
EXPO_PUBLIC_COGNITO_USER_POOL_ID=your-region_YourPoolId

# Cognito App Client ID
EXPO_PUBLIC_COGNITO_CLIENT_ID=your-client-id
